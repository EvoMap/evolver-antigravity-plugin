{
  "evolver-antigravity-plugin": {
    "PreInvocation": [
      {
        "type": "command",
        "command": "PLUGIN_ROOT=\"${ANTIGRAVITY_PLUGIN_ROOT:-$HOME/.gemini/config/plugins/evolver-antigravity-plugin}\"; node \"$PLUGIN_ROOT/hooks/session-start.js\"",
        "timeout": 5
      }
    ],
    "PostToolUse": [
      {
        "matcher": "write_to_file|replace_file_content|multi_replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_ROOT=\"${ANTIGRAVITY_PLUGIN_ROOT:-$HOME/.gemini/config/plugins/evolver-antigravity-plugin}\"; node \"$PLUGIN_ROOT/hooks/signal-detect.js\"",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "PLUGIN_ROOT=\"${ANTIGRAVITY_PLUGIN_ROOT:-$HOME/.gemini/config/plugins/evolver-antigravity-plugin}\"; node \"$PLUGIN_ROOT/hooks/session-end.js\"",
        "timeout": 10
      }
    ]
  }
}
